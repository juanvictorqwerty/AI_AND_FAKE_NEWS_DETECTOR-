# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/news_auth_check

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google Fact Check Tools API
# Get your API key from: https://developers.google.com/fact-check/tools/api
GOOGLE_FACT_CHECK_API_KEY=your-google-fact-check-api-key-here

# Google Custom Search API (Optional - for web search functionality)
# Get your API key from: https://developers.google.com/custom-search/v1/overview
# Create a search engine at: https://cse.google.com/cse/
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# SerpAPI Alternative (Optional)
# Get your API key from: https://serpapi.com/
SERP_API_KEY=your-serpapi-key

# Rate Limiting (Optional)
# FACT_CHECK_RATE_LIMIT=100
# FACT_CHECK_RATE_LIMIT_WINDOW=3600000
